local Players = game:GetService("Players")
local UIS = game:GetService("UserInputService")
local RunService = game:GetService("RunService")

local player = Players.LocalPlayer
local camera = workspace.CurrentCamera

-- SETTINGS
local enabled = false
local SPEED = 30.4
local WALL_SPEED = 9

local character, hrp, humanoid
local sphere
local gui

local function createGUI()
	if gui then gui:Destroy() end

	gui = Instance.new("ScreenGui")
	gui.Name = "SphereSettings"
	gui.ResetOnSpawn = false
	gui.Parent = player:WaitForChild("PlayerGui")

	local frame = Instance.new("Frame")
	frame.Size = UDim2.new(0, 220, 0, 140)
	frame.Position = UDim2.new(0, 20, 0.5, -70)
	frame.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
	frame.BackgroundTransparency = 0.2
	frame.Parent = gui

	local title = Instance.new("TextLabel")
	title.Size = UDim2.new(1, 0, 0, 30)
	title.Text = "Sphere Settings"
	title.TextColor3 = Color3.fromRGB(255,255,255)
	title.BackgroundTransparency = 1
	title.Parent = frame

	local speedLabel = Instance.new("TextLabel")
	speedLabel.Size = UDim2.new(1, 0, 0, 25)
	speedLabel.Position = UDim2.new(0, 0, 0, 35)
	speedLabel.Text = "Speed: " .. SPEED
	speedLabel.TextColor3 = Color3.fromRGB(200,200,200)
	speedLabel.BackgroundTransparency = 1
	speedLabel.Parent = frame

	local increase = Instance.new("TextButton")
	increase.Size = UDim2.new(0.5, -5, 0, 40)
	increase.Position = UDim2.new(0, 5, 0, 70)
	increase.Text = "+ Speed"
	increase.Parent = frame

	local decrease = Instance.new("TextButton")
	decrease.Size = UDim2.new(0.5, -5, 0, 40)
	decrease.Position = UDim2.new(0.5, 0, 0, 70)
	decrease.Text = "- Speed"
	decrease.Parent = frame

	increase.MouseButton1Click:Connect(function()
		SPEED += 5
		speedLabel.Text = "Speed: " .. SPEED
	end)

	decrease.MouseButton1Click:Connect(function()
		SPEED = math.max(1, SPEED - 5)
		speedLabel.Text = "Speed: " .. SPEED
	end)
end

local function setupCharacter(char)
	character = char
	humanoid = char:WaitForChild("Humanoid")
	hrp = char:WaitForChild("HumanoidRootPart")

	humanoid.CameraOffset = Vector3.new(0, 5, 0)

	for _, v in ipairs(char:GetDescendants()) do
		if v:IsA("BasePart") then
			v.Transparency = 1
			v.CanCollide = false
		end
	end

	if sphere then sphere:Destroy() end

	sphere = Instance.new("Part")
	sphere.Shape = Enum.PartType.Ball
	sphere.Size = Vector3.new(5,5,5)
	sphere.Material = Enum.Material.Neon
	sphere.Color = Color3.fromRGB(0,170,255)
	sphere.Anchored = false
	sphere.CanCollide = false
	sphere.Massless = true
	sphere.Parent = workspace

	local weld = Instance.new("WeldConstraint")
	weld.Part0 = sphere
	weld.Part1 = hrp
	weld.Parent = sphere

	sphere.CFrame = hrp.CFrame
end

local function isWall(dir)
	if dir.Magnitude == 0 then return false end

	local params = RaycastParams.new()
	params.FilterDescendantsInstances = {character}
	params.FilterType = Enum.RaycastFilterType.Blacklist

	local result = workspace:Raycast(hrp.Position, dir.Unit * 3, params)
	return result ~= nil
end

local function enable()
	if enabled then return end
	enabled = true

	setupCharacter(player.Character or player.CharacterAdded:Wait())
	createGUI()

	RunService.RenderStepped:Connect(function(dt)
		if not hrp then return end

		local moveDir = humanoid.MoveDirection
		local camCF = camera.CFrame

		local forward = Vector3.new(camCF.LookVector.X, 0, camCF.LookVector.Z).Unit
		local right = Vector3.new(camCF.RightVector.X, 0, camCF.RightVector.Z).Unit

		local dir = forward * moveDir.Z + right * moveDir.X
		if dir.Magnitude > 1 then dir = dir.Unit end

		local wall = isWall(dir)

		-- noclip when needed
		for _, v in ipairs(character:GetDescendants()) do
			if v:IsA("BasePart") then
				v.CanCollide = not wall
			end
		end

		local speed = wall and WALL_SPEED or SPEED

		-- FLIGHT HEIGHT CONTROL (W/S up/down)
		if UIS:IsKeyDown(Enum.KeyCode.Space) then
			dir += Vector3.new(0, 1, 0)
		end
		if UIS:IsKeyDown(Enum.KeyCode.LeftShift) then
			dir += Vector3.new(0, -1, 0)
		end

		if dir.Magnitude > 0 then
			dir = dir.Unit
		end

		hrp.CFrame = hrp.CFrame + dir * speed * dt

		camera.CFrame = CFrame.new(hrp.Position + Vector3.new(0, 6, 12), hrp.Position)
	end)
end

local function disable()
	enabled = false

	if gui then gui:Destroy() gui = nil end

	if sphere then sphere:Destroy() sphere = nil end

	if character then
		for _, v in ipairs(character:GetDescendants()) do
			if v:IsA("BasePart") then
				v.Transparency = 0
				v.CanCollide = true
			end
		end
	end

	if humanoid then
		humanoid.CameraOffset = Vector3.new(0,0,0)
	end
end

UIS.InputBegan:Connect(function(input, gp)
	if gp then return end
	if input.KeyCode == Enum.KeyCode.F then
		if enabled then
			disable()
		else
			enable()
		end
	end
end)

player.CharacterAdded:Connect(function()
	task.wait(1)
	if enabled then
		disable()
		enable()
	end
end)
