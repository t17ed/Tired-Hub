--// SETUP CHARACTER
local function setupChar(char)
	character = char
	hrp = char:WaitForChild("HumanoidRootPart")
	humanoid = char:WaitForChild("Humanoid")
end

setupChar(character)

--// CUBE CREATION
local function enableCube()
	if cube then cube:Destroy() end

	for _,v in pairs(character:GetDescendants()) do
		if v:IsA("BasePart") then
			v.Transparency = 1
			v.CanCollide = false
		end
	end

	cube = Instance.new("Part")
	cube.Size = Vector3.new(4,4,4)
	cube.Material = Enum.Material.Neon
	cube.Color = Color3.fromRGB(170, 0, 255)
	cube.Anchored = false
	cube.CanCollide = false
	cube.Name = "Cube"
	cube.Parent = workspace

	local weld = Instance.new("WeldConstraint")
	weld.Part0 = cube
	weld.Part1 = hrp
	weld.Parent = cube

	cube.CFrame = hrp.CFrame
	cubeEnabled = true

	humanoid.WalkSpeed = moveSpeed
end

local function disableCube()
	if cube then cube:Destroy() end
	cubeEnabled = false

	for _,v in pairs(character:GetDescendants()) do
		if v:IsA("BasePart") then
			v.Transparency = 0
			v.CanCollide = true
		end
	end
end

--// NOCLIP LOOP
RunService.Stepped:Connect(function()
	if character then
		for _,v in pairs(character:GetDescendants()) do
			if v:IsA("BasePart") then
				v.CanCollide = false
			end
		end
	end
end)

--// SPEED UPDATE
local function updateSpeed()
	local s = tonumber(speedBox.Text)
	if s then
		moveSpeed = s
		if humanoid then
			TweenService:Create(
				humanoid,
				TweenInfo.new(0.3),
				{WalkSpeed = moveSpeed}
			):Play()
		end
	end
end

speedBox.FocusLost:Connect(updateSpeed)

--// TWEEN TO POSITION (SPEED BASED)
local function tweenToPosition(pos)
	if not hrp or tweening then return end
	tweening = true

	local dist = (hrp.Position - pos).Magnitude
	local duration = dist / math.max(moveSpeed, 1)

	local tween = TweenService:Create(
		hrp,
		TweenInfo.new(duration, Enum.EasingStyle.Linear),
		{CFrame = CFrame.new(pos)}
	)

	tween:Play()
	tween.Completed:Wait()

	tweening = false
end

--// KEYBIND (F)
UserInputService.InputBegan:Connect(function(input, gpe)
	if gpe then return end
	if input.KeyCode == Enum.KeyCode.F then
		if savedPosition then
			tweenToPosition(savedPosition)
		end
	end
end)

--// UI EVENTS
toggle.MouseButton1Click:Connect(function()
	if cubeEnabled then
		disableCube()
		toggle.Text = "Enable Cube"
	else
		enableCube()
		toggle.Text = "Disable Cube"
	end
end)

