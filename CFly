--// SPEED INPUT
local speedBox = Instance.new("TextBox")
speedBox.Size = UDim2.new(0.9, 0, 0, 30)
speedBox.Position = UDim2.new(0.05, 0, 0.75, 0)
speedBox.BackgroundColor3 = Color3.fromRGB(40, 0, 60)
speedBox.Text = "31.6"
speedBox.TextColor3 = Color3.new(1,1,1)
speedBox.Font = Enum.Font.Gotham
speedBox.TextSize = 13
speedBox.PlaceholderText = "WalkSpeed"
speedBox.Parent = frame
Instance.new("UICorner", speedBox)

--// CUBE VARIABLES
local cube
local spinConn

local function makeCube(char)
	local hrp = char:WaitForChild("HumanoidRootPart")
	local humanoid = char:WaitForChild("Humanoid")

	-- hide character
	for _,v in pairs(char:GetChildren()) do
		if v:IsA("BasePart") then
			v.Transparency = 1
			v.CanCollide = false
		end
	end

	-- cube
	cube = Instance.new("Part")
	cube.Size = Vector3.new(4,4,4)
	cube.Shape = Enum.PartType.Block
	cube.Material = Enum.Material.Neon
	cube.Color = Color3.fromRGB(170, 0, 255)
	cube.Anchored = false
	cube.CanCollide = false
	cube.Name = "NeonCube"
	cube.Parent = workspace

	local weld = Instance.new("WeldConstraint")
	weld.Part0 = cube
	weld.Part1 = hrp
	weld.Parent = cube

	cube.CFrame = hrp.CFrame

	-- spin effect
	spinConn = RunService.RenderStepped:Connect(function(dt)
		if cube and cube.Parent then
			cube.CFrame = cube.CFrame * CFrame.Angles(0, math.rad(180 * dt * spinSpeed), 0)
		end
	end)

	humanoid.WalkSpeed = targetWalkSpeed
end

local function removeCube(char)
	if spinConn then spinConn:Disconnect() end
	if cube then cube:Destroy() end

	for _,v in pairs(char:GetChildren()) do
		if v:IsA("BasePart") then
			v.Transparency = 0
			v.CanCollide = true
		end
	end
end

local function applySpeed(char)
	local hum = char:FindFirstChildOfClass("Humanoid")
	if hum then
		local newSpeed = tonumber(speedBox.Text)
		if newSpeed then
			TweenService:Create(
				hum,
				TweenInfo.new(0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
				{WalkSpeed = newSpeed}
			):Play()
		end
	end
end

--// EVENTS
toggle.MouseButton1Click:Connect(function()
	character = player.Character or player.CharacterAdded:Wait()

	cubeEnabled = not cubeEnabled

	if cubeEnabled then
		toggle.Text = "Disable Cube"
		makeCube(character)
	else
		toggle.Text = "Enable Neon Cube"
		removeCube(character)
	end
end)

reset.MouseButton1Click:Connect(function()
	player:LoadCharacter()
end)

speedBox.FocusLost:Connect(function()
	if cubeEnabled then
		applySpeed(character)
	end
end)

--// auto reapply on respawn
player.CharacterAdded:Connect(function(char)
	character = char
	task.wait(0.5)

	if cubeEnabled then
		makeCube(char)
	end
end)
